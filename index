<script>
function copyColor(el,hex){navigator.clipboard.writeText(hex);el.classList.add('copied');setTimeout(()=>el.classList.remove('copied'),1500)}
const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('vis')}),{threshold:.1});
document.querySelectorAll('.rv').forEach(el=>obs.observe(el));
let ly=0;const nav=document.getElementById('nav');
window.addEventListener('scroll',()=>{
  const y=window.scrollY;nav.classList.toggle('hide',y>ly&&y>80);ly=y;
  document.querySelectorAll('section[id]').forEach(s=>{
    if(window.scrollY>=s.offsetTop-120){
      const a=document.querySelector(`.nav-links a[href="#${s.id}"]`);
      if(a){document.querySelectorAll('.nav-links a').forEach(x=>x.classList.remove('on'));a.classList.add('on');}
    }
  });
});
</script>
