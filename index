    </div>
  </div>

  <div style="margin-top:44px" class="rv">
    <div class="sub">Combinações aprovadas</div>
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
      <div style="border-radius:14px;padding:24px;background:#1E1118;display:flex;flex-direction:column;gap:8px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:22px;color:#D8B8B0">Dr. Rafaela</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;letter-spacing:3px;color:#9B7080">MEDICINA · SAÚDE MENTAL</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;color:#B5747D;margin-top:4px;opacity:.6">Noite + Blush</div>
      </div>
      <div style="border-radius:14px;padding:24px;background:#5B2D45;display:flex;flex-direction:column;gap:8px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:22px;color:#EFE3DC">Dr. Rafaela</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;letter-spacing:3px;color:rgba(239,227,220,.4)">MEDICINA · SAÚDE MENTAL</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;color:rgba(239,227,220,.35);margin-top:4px">Vinho + Creme</div>
      </div>
      <div style="border-radius:14px;padding:24px;background:#EFE3DC;display:flex;flex-direction:column;gap:8px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:22px;color:#5B2D45">Dr. Rafaela</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;letter-spacing:3px;color:#9B7080">MEDICINA · SAÚDE MENTAL</div>
        <div style="font-family:'Jost',sans-serif;font-size:9px;color:#B5747D;margin-top:4px;opacity:.6">Creme + Vinho</div>
      </div>
    </div>
  </div>
</section>

<!-- TYPOGRAPHY -->
<section class="type-sec pad" id="type">
  <div class="rv">
    <div class="sh-num">04 — Tipografia</div>
    <div class="sh-title">Sistema <em>tipográfico</em></div>
    <div class="sh-desc">Cormorant Garamond para identidade e títulos. Jost para textos funcionais e interfaces digitais.</div>
    <div class="sh-line"></div>
  </div>

  <div class="tgrid rv">
    <div class="tcard">
      <div class="tcard-name">Primária — Cormorant Garamond</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:54px;font-weight:300;color:var(--blush);line-height:1">Aa</div>
      <div style="margin-top:14px">
        <div style="font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:400;color:var(--blush)">Medicina com presença</div>
        <div style="font-family:'Cormorant Garamond',serif;font-style:italic;font-size:17px;color:var(--mauve);margin-top:4px">Cuidado com intenção</div>
      </div>
      <div class="tcard-meta">Títulos, nome da marca, assinaturas, cabeçalhos. Pesos: Light 300, Regular 400, Medium 500. Disponível no Google Fonts.</div>
    </div>
    <div class="tcard">
      <div class="tcard-name">Secundária — Jost</div>
      <div style="font-family:'Jost',sans-serif;font-size:54px;font-weight:200;color:var(--blush);line-height:1">Aa</div>
