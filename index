<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dr. Rafaela Cachiolo — Brand Guidelines</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --wine:#5B2D45;
  --mauve:#B5747D;
  --blush:#D8B8B0;
  --cream:#EFE3DC;
  --deep:#1E1118;
  --offwhite:#FAF5F7;
  --white:#FFFFFF;
  --mist:#9B7080;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{background:var(--deep);color:var(--blush);font-family:'Jost',sans-serif;overflow-x:hidden;-webkit-font-smoothing:antialiased}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--deep)}::-webkit-scrollbar-thumb{background:var(--mauve);border-radius:2px}

.nav{position:fixed;top:0;left:0;right:0;z-index:100;padding:14px 40px;display:flex;justify-content:space-between;align-items:center;backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);background:rgba(30,17,24,.85);border-bottom:1px solid rgba(216,184,176,.04);transition:transform .4s}
.nav.hide{transform:translateY(-100%)}
.nav-brand{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:400;color:var(--blush);letter-spacing:.5px}
.nav-brand em{font-style:italic;color:var(--mauve)}
.nav-links{display:flex;gap:20px}
.nav-links a{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:2.5px;text-transform:uppercase;color:var(--mist);text-decoration:none;transition:color .3s;opacity:.7}
.nav-links a:hover,.nav-links a.on{color:var(--blush);opacity:1}
@media(max-width:768px){.nav-links{display:none}}

section{min-height:100vh;position:relative}
.pad{padding:100px 64px 80px}
@media(max-width:900px){.pad{padding:80px 28px 60px}}

.sh-num{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:4px;text-transform:uppercase;color:var(--mauve);opacity:.8}
.sh-title{font-family:'Cormorant Garamond',serif;font-size:clamp(26px,4vw,42px);font-weight:400;line-height:1.2;margin-top:8px;color:var(--blush)}
.sh-title.dk{color:var(--wine)}
.sh-title em{font-style:italic;color:var(--mauve)}
.sh-desc{font-family:'Jost',sans-serif;font-weight:300;font-size:13px;color:var(--mist);margin-top:12px;max-width:520px;line-height:1.85}
.sh-line{width:28px;height:1px;background:var(--mauve);margin-top:16px;margin-bottom:48px;opacity:.5}
.sub{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--mauve);opacity:.6;margin-bottom:16px}

.rv{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s ease}
.rv.vis{opacity:1;transform:none}

/* COVER */
.cover{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;min-height:100vh;background:var(--deep);padding:40px;position:relative;overflow:hidden}
.cover::before{content:'';position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(91,45,69,.3) 0%,transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none}
.cover-logo{width:clamp(140px,20vw,200px);height:auto;border-radius:12px;opacity:0;animation:fu .9s .2s forwards}
.cover-name{font-family:'Cormorant Garamond',serif;font-size:clamp(13px,2vw,18px);font-weight:300;letter-spacing:6px;text-transform:uppercase;color:var(--blush);margin-top:28px;opacity:0;animation:fu .9s .5s forwards}
.cover-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:clamp(11px,1.6vw,14px);font-weight:300;letter-spacing:3px;color:var(--mauve);margin-top:6px;opacity:0;animation:fu .9s .7s forwards}
.cover-line{width:36px;height:1px;background:var(--mauve);margin:30px auto;opacity:0;animation:fu .9s 1s forwards}
.cover-label{font-family:'Jost',sans-serif;font-size:8px;letter-spacing:5px;text-transform:uppercase;color:var(--mauve);opacity:0;animation:fu .9s 1.2s forwards}
.cover-sub{font-family:'Jost',sans-serif;font-weight:300;font-size:12px;color:var(--mist);margin-top:6px;opacity:0;animation:fu .9s 1.4s forwards}
.cover-yr{font-family:'Jost',sans-serif;font-size:9px;color:var(--mist);margin-top:4px;opacity:0;animation:fu .9s 1.6s forwards}
.cover-arrow{position:absolute;bottom:32px;left:50%;transform:translateX(-50%);opacity:0;animation:fu .9s 2s forwards,bob 2s 3s infinite ease-in-out}
.cover-arrow svg{width:16px;stroke:var(--mauve);stroke-width:1.5;fill:none;opacity:.5}
@keyframes fu{0%{opacity:0;transform:translateY(16px)}100%{opacity:1;transform:none}}
@keyframes bob{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(7px)}}

/* ABOUT */
.about{background:var(--offwhite);color:var(--wine)}
.about-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px}
@media(max-width:900px){.about-grid{grid-template-columns:1fr}}
.about-text{font-family:'Jost',sans-serif;font-weight:300;font-size:14px;color:var(--mist);line-height:1.9}
.about-text p+p{margin-top:14px}
.attr{display:flex;gap:12px;padding:12px 16px;border-radius:10px;background:rgba(91,45,69,.03);transition:background .3s;margin-bottom:8px}
.attr:hover{background:rgba(181,116,125,.06)}
.attr-dot{width:4px;height:4px;border-radius:50%;background:var(--mauve);margin-top:9px;flex-shrink:0}
.attr strong{font-weight:500;color:var(--wine);font-family:'Cormorant Garamond',serif;font-size:17px}
.attr span{color:var(--mist);font-weight:300;font-size:13px}

/* LOGO */
.logo-sec{background:var(--deep)}
.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
@media(max-width:900px){.grid3{grid-template-columns:1fr}}
.lcard{border-radius:20px;padding:36px 28px;display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:260px;transition:transform .4s cubic-bezier(.22,1,.36,1)}
.lcard:hover{transform:translateY(-3px)}
.lcard.dk{background:var(--deep);border:1px solid rgba(216,184,176,.07)}
.lcard.lt{background:var(--offwhite)}
.lcard.wn{background:var(--wine)}
.lcard.cr{background:var(--cream)}
.lcard-logo{width:120px;height:auto;border-radius:8px}
.lcard-lbl{font-family:'Jost',sans-serif;font-size:8px;letter-spacing:2px;text-transform:uppercase;margin-top:16px;opacity:.3}

/* COLORS */
.colors-sec{background:var(--offwhite);color:var(--wine)}
.cgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
@media(min-width:700px){.cgrid{grid-template-columns:repeat(4,1fr)}}
.ccard{border-radius:16px;overflow:hidden;cursor:pointer;transition:transform .3s,box-shadow .3s;background:var(--white);box-shadow:0 2px 20px rgba(91,45,69,.06)}
.ccard:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(91,45,69,.1)}
.cswatch{height:140px;position:relative}
.cswatch .flash{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,.4);color:#fff;font-family:'Jost',sans-serif;font-size:10px;letter-spacing:2px;opacity:0;transition:opacity .25s}
.ccard.copied .flash{opacity:1}
.cinfo{padding:14px 16px}
.cname{font-family:'Cormorant Garamond',serif;font-size:17px;font-weight:500;color:var(--wine)}
.chex{font-family:'Jost',sans-serif;font-size:11px;color:var(--mist);margin-top:2px;letter-spacing:.5px}
.crole{font-family:'Jost',sans-serif;font-size:10px;color:var(--mauve);margin-top:4px;letter-spacing:.5px;opacity:.8}

/* TYPOGRAPHY */
.type-sec{background:var(--deep)}
.tgrid{display:grid;grid-template-columns:1fr 1fr;gap:28px;margin-bottom:44px}
@media(max-width:900px){.tgrid{grid-template-columns:1fr}}
.tcard{border-radius:18px;padding:36px;border:1px solid rgba(216,184,176,.07);background:rgba(216,184,176,.02)}
.tcard-name{font-family:'Jost',sans-serif;font-size:9px;letter-spacing:3px;text-transform:uppercase;color:var(--mauve);opacity:.6;margin-bottom:18px}
.tcard-meta{font-family:'Jost',sans-serif;font-size:11px;color:var(--mist);margin-top:16px;line-height:1.7;opacity:.7}
.type-scale{display:flex;flex-direction:column;gap:20px;padding:36px;border-radius:18px;border:1px solid rgba(216,184,176,.05);background:rgba(216,184,176,.015)}

/* VOICE */
.voice-sec{background:var(--offwhite)}
.vgrid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
@media(max-width:900px){.vgrid{grid-template-columns:1fr}}
.vcard{border-radius:18px;padding:32px;background:var(--white);box-shadow:0 2px 24px rgba(91,45,69,.06)}
.vcard-head{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.vcard-dot{width:5px;height:5px;border-radius:50%;background:var(--mauve)}
.vcard-title{font-family:'Cormorant Garamond',serif;font-size:19px;font-weight:500;color:var(--wine)}
.vcard-text{font-family:'Jost',sans-serif;font-weight:300;font-size:13px;color:var(--mist);line-height:1.85}
.vcard-ex{margin-top:14px;padding:12px 16px;border-radius:10px;background:rgba(91,45,69,.04);border-left:2px solid var(--mauve)}
.vcard-ex p{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:15px;color:var(--wine)}
.vcard-ex small{font-family:'Jost',sans-serif;font-size:10px;color:var(--mist);display:block;margin-top:4px;letter-spacing:.5px}

/* APPS */
.app-sec{background:var(--deep)}
.app-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:900px){.app-grid{grid-template-columns:1fr}}

/* FOOTER */
.foot{background:var(--deep);border-top:1px solid rgba(216,184,176,.06);padding:52px 64px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:24px}
.foot-brand{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--blush)}
.foot-brand em{font-style:italic;color:var(--mauve)}
.foot-note{font-family:'Jost',sans-serif;font-size:11px;color:var(--mist);opacity:.4;text-align:right}
</style>
</head>
<body>

<nav class="nav" id="nav">
  <div class="nav-brand">Dr. Rafaela <em>Cachiolo</em></div>
  <div class="nav-links">
    <a href="#about">A Marca</a>
    <a href="#logo">Logo</a>
    <a href="#colors">Cores</a>
    <a href="#type">Tipografia</a>
    <a href="#voice">Voz</a>
    <a href="#apps">Aplicações</a>
  </div>
</nav>

<!-- COVER -->
<section class="cover" id="cover">
  <img class="cover-logo" src="data:image/png;base64," alt="Dr. Rafaela Cachiolo"/>
  <div class="cover-name">Dr. Rafaela Cachiolo</div>
  <div class="cover-title">Medicina · Saúde Mental</div>
  <div class="cover-line"></div>
  <div class="cover-label">Brand Guidelines</div>
  <div class="cover-sub">Manual de Identidade Visual</div>
  <div class="cover-yr">2026</div>
  <div class="cover-arrow"><svg viewBox="0 0 24 24"><path d="M12 5v14M5 12l7 7 7-7"/></svg></div>
</section>

<!-- ABOUT -->
<section class="about pad" id="about">
  <div class="rv">
    <div class="sh-num">01 — A Marca</div>
    <div class="sh-title dk">Sobre a <em>Dr. Rafaela</em></div>
    <div class="sh-line" style="background:var(--mauve)"></div>
  </div>
  <div class="about-grid">
    <div class="about-text rv">
      <p>A marca Dr. Rafaela Cachiolo representa uma medicina exercida com intenção — técnica rigorosa aliada à escuta genuína. Formada pela Universidade Federal do Paraná, com trajetória voltada à psiquiatria e à saúde mental, a Dr. Rafaela atua na intersecção entre a ciência e o cuidado humano.</p>
      <p>Seja em atendimentos presenciais, plantões ou consultas online, a essência permanece a mesma: presença real com cada paciente. A identidade visual traduz essa filosofia — elegância contida, acolhimento sem excessos, sofisticação que não intimida.</p>
      <p>O monograma RC e a ilustração das mãos em acolhimento sintetizam o que a marca representa: competência médica e humanidade se encontrando.</p>
    </div>
    <div class="rv">
      <div class="sub" style="color:var(--mauve)">Atributos da marca</div>
      <div class="attr"><div class="attr-dot"></div><div><strong>Acolhedora</strong> <span>— Presença que conforta</span></div></div>
      <div class="attr"><div class="attr-dot"></div><div><strong>Rigorosa</strong> <span>— Ciência sem concessões</span></div></div>
      <div class="attr"><div class="attr-dot"></div><div><strong>Elegante</strong> <span>— Sofisticação discreta</span></div></div>
      <div class="attr"><div class="attr-dot"></div><div><strong>Humana</strong> <span>— Técnica com empatia</span></div></div>
      <div class="attr"><div class="attr-dot"></div><div><strong>Confiável</strong> <span>— Segurança que se sente</span></div></div>
      <div style="margin-top:28px" class="sub" style="color:var(--mauve)">Tom de voz</div>
      <div class="about-text"><p>Calma que transmite segurança. Linguagem clara e acessível, nunca distante. Técnica sem jargão desnecessário — a Dr. Rafaela fala com o paciente, não para ele.</p></div>
    </div>
  </div>
</section>

<!-- LOGO -->
<section class="logo-sec pad" id="logo">
  <div class="rv">
    <div class="sh-num">02 — Logo</div>
    <div class="sh-title">A <em>identidade</em> visual</div>
    <div class="sh-desc">Monograma RC com ilustração de mãos em acolhimento. Linhas delicadas que traduzem cuidado e precisão.</div>
    <div class="sh-line"></div>
  </div>

  <div class="sub rv">Logo principal — 3 versões de fundo</div>
  <div class="grid3 rv">
    <div class="lcard dk">
      <img class="lcard-logo" src="data:image/png;base64," alt="Logo fundo escuro"/>
      <div class="lcard-lbl" style="color:var(--blush)">Fundo escuro</div>
    </div>
    <div class="lcard wn">
      <img class="lcard-logo" src="data:image/png;base64," alt="Logo fundo vinho"/>
      <div class="lcard-lbl" style="color:var(--cream)">Fundo vinho</div>
    </div>
    <div class="lcard cr">
      <img class="lcard-logo" style="border-radius:8px" src="data:image/png;base64," alt="Logo fundo creme"/>
      <div class="lcard-lbl" style="color:var(--wine)">Fundo creme</div>
    </div>
  </div>

  <div style="margin-top:44px" class="rv">
    <div class="sub">Zona de proteção e usos incorretos</div>
    <div style="background:rgba(216,184,176,.025);border-radius:18px;padding:32px 36px;border:1px solid rgba(216,184,176,.05);display:flex;flex-direction:column;gap:16px">
      <div style="display:flex;align-items:center;gap:14px"><div style="width:5px;height:5px;border-radius:50%;background:#cf6679;flex-shrink:0"></div><div style="font-family:'Jost',sans-serif;font-size:13px;color:var(--mist);font-weight:300">Não distorcer ou redimensionar desproporcionalmente</div></div>
      <div style="display:flex;align-items:center;gap:14px"><div style="width:5px;height:5px;border-radius:50%;background:#cf6679;flex-shrink:0"></div><div style="font-family:'Jost',sans-serif;font-size:13px;color:var(--mist);font-weight:300">Não aplicar sobre fundos com baixo contraste ou padrões que comprometam a leitura</div></div>
      <div style="display:flex;align-items:center;gap:14px"><div style="width:5px;height:5px;border-radius:50%;background:#cf6679;flex-shrink:0"></div><div style="font-family:'Jost',sans-serif;font-size:13px;color:var(--mist);font-weight:300">Não recolorir com paletas fora do sistema de cores oficial</div></div>
      <div style="display:flex;align-items:center;gap:14px"><div style="width:5px;height:5px;border-radius:50%;background:#cf6679;flex-shrink:0"></div><div style="font-family:'Jost',sans-serif;font-size:13px;color:var(--mist);font-weight:300">Não adicionar sombras, gradientes ou efeitos não autorizados</div></div>
      <div style="display:flex;align-items:center;gap:14px"><div style="width:5px;height:5px;border-radius:50%;background:#cf6679;flex-shrink:0"></div><div style="font-family:'Jost',sans-serif;font-size:13px;color:var(--mist);font-weight:300">Manter espaço de proteção equivalente à altura do "R" ao redor da logo em todos os lados</div></div>
    </div>
  </div>
</section>

<!-- COLORS -->
<section class="colors-sec pad" id="colors">
  <div class="rv">
    <div class="sh-num">03 — Cores</div>
    <div class="sh-title dk">Paleta <em>Ameixa Moderna</em></div>
    <div class="sh-desc">Quatro tons extraídos diretamente da identidade. Vinho profundo, malva, blush rosado e creme acolhedor.</div>
    <div class="sh-line" style="background:var(--mauve)"></div>
  </div>

  <div class="cgrid rv">
    <div class="ccard" onclick="copyColor(this,'#5B2D45')">
      <div class="cswatch" style="background:#5B2D45"><div class="flash">COPIADO</div></div>
      <div class="cinfo"><div class="cname">Vinho</div><div class="chex">#5B2D45</div><div class="crole">Cor primária · fundos e marca</div></div>
    </div>
    <div class="ccard" onclick="copyColor(this,'#B5747D')">
      <div class="cswatch" style="background:#B5747D"><div class="flash">COPIADO</div></div>
      <div class="cinfo"><div class="cname">Malva</div><div class="chex">#B5747D</div><div class="crole">Cor secundária · acentos e detalhes</div></div>
    </div>
    <div class="ccard" onclick="copyColor(this,'#D8B8B0')">
      <div class="cswatch" style="background:#D8B8B0"><div class="flash">COPIADO</div></div>
      <div class="cinfo"><div class="cname">Blush</div><div class="chex">#D8B8B0</div><div class="crole">Tom de apoio · tipografia em escuro</div></div>
    </div>
    <div class="ccard" onclick="copyColor(this,'#EFE3DC')">
      <div class="cswatch" style="background:#EFE3DC"><div class="flash">COPIADO</div></div>
